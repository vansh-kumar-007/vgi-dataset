# --- Data (never commit pulled/generated data — lives on Kaggle Datasets, not git) ---
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# --- Secrets (NEVER commit real keys) ---
*.env
!config/secrets.example.env
secrets.env
config/secrets.env

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Environments ---
.venv/
venv/
env/

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- Kaggle upload staging folders (large data files, not source code) ---
kaggle_upload/
kaggle_metadata_check*/